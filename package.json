{
    "name": "consumer-react",
    "version": "0.0.3",
    "description": "Consume your apis in React projects quickly and easily",
    "main": "dist/index.js",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.js",
    "scripts": {
        "build": "tsup",
        "ci": "pnpm run build && pnpm run check-format && pnpm run check-exports && pnpm run lint && pnpm run test",
        "format": "prettier --write .",
        "check-format": "prettier --check .",
        "check-exports": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
        "lint": "tsc",
        "test": "vitest run",
        "dev": "vitest",
        "local-release": "changeset version && changeset tag",
        "prepublishOnly": "pnpm run ci"
    },
    "keywords": [],
    "homepage": "https://github.com/binhodev/consumer-react",
    "bugs": {
        "url": "https://github.com/binhodev/consumer-react/issues"
    },
    "author": "Binho.dev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/binhodev/consumer-react.git"
    },
    "files": [
        "dist",
        "package.json"
    ],
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "import": "./dist/index.js",
            "default": "./dist/index.cjs"
        }
    },
    "type": "module",
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.17.3",
        "@changesets/cli": "^2.27.12",
        "prettier": "^3.4.2",
        "react": "^19.0.0",
        "tsup": "^8.3.6",
        "typescript": "^5.7.3",
        "vitest": "^3.0.4"
    },
    "peerDependencies": {
        "react": "^19.0.0"
    },
    "dependencies": {
        "axios": "^1.7.9",
        "zod": "^3.24.1"
    }
}
